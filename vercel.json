{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "database_store.json",
        "firebase-applet-config.json"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
