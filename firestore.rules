rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Centralized store collections managed and authenticated by the backend server
    match /store/{collectionName} {
      allow read, write: if true;
    }
  }
}
